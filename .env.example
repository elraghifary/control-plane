# Required: Auth.js session signing + PAT encryption key (HKDF-derived).
# Generate with: npx auth secret (or: openssl rand -base64 33)
AUTH_SECRET=

# Optional: comma-separated GitHub org logins — only these org repos appear in the selector.
# Example: CONTROL_PLANE_GITHUB_ORGS=happykids-id
CONTROL_PLANE_GITHUB_ORGS=

# Required: Postgres connection string for the control plane's own database (users/invites).
DB_CONTROL_PLANE=

# Required: only needed for the ClickUp PR/sign-off integrations (dashboard, releases pages).
CLICKUP_BASE_URL=https://api.clickup.com/api/v3
CLICKUP_PERSONAL_TOKEN_SUPPORT=
CLICKUP_PERSONAL_TOKEN_ELRA=
CLICKUP_WORKSPACE_ID=
CLICKUP_CHANNEL_ID=
CLICKUP_SIGNOFF_SPRINT_FOLDER_ID=
CLICKUP_SIGNOFF_DOCS_FOLDER_ID=
CLICKUP_SIGNOFF_ASSIGNEE_IDS=

# Required: only needed for the Releases → Release Production Jenkins trigger.
# The job triggered is "<repo-name>-release" (e.g. repo "website" -> job "website-release").
JENKINS_BASE_URL=
JENKINS_USERNAME=
JENKINS_API_TOKEN=
JENKINS_JOB_TOKEN=

# Required: only needed for the Apps page. Must match the values already used by the
# app-secrets tool and the HappyKids mobile app — this is a second writer to the same Firestore
# projects and ciphertext, not a separate store.
ENCRYPTION_KEY=
FIREBASE_SA_DEVELOPMENT=
FIREBASE_SA_PREVIEW=
FIREBASE_SA_PRODUCTION=

# Optional: only needed to build/push the Docker image and (later) deploy to GKE.
GCP_PROJECT_ID=
GCP_PROJECT_ZONE=
GCP_PROJECT_CLUSTER=
GCP_SA_JSON=
