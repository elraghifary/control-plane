# Required: Auth.js session signing + PAT encryption key (HKDF-derived).
# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=

# Optional: comma-separated GitHub org logins — only these org repos appear in the selector.
# Example: CONTROL_PLANE_GITHUB_ORGS=happykids-id
CONTROL_PLANE_GITHUB_ORGS=
